generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

/**
 * בכל שלב של הוספת טבלה יש להריץ את הפקודות:
 * npx prisma generate
 * npx prisma db push
 */

// טבלה חדשה לאחסון פרטי פוליסות
model Policy {
  id            String   @id @default(cuid())
  policyNumber  String   @unique
  branchNumber  Int
  premiumAmount Decimal  @db.Decimal(15, 2)
  startDate     DateTime
  endDate       DateTime
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
}

// טבלה לאחסון UPR, DUC ופרמיה מקורית לכל ענף ותקופה
model UprSnapshot {
  id              String   @id @default(cuid())
  year            Int
  period          Int
  periodType      String   @default("MONTHLY")
  branchNumber    Int

  // פרמיה כתובה ברוטו
  originalPremium Decimal  @default(0) @db.Decimal(15, 2)

  // UPR — עתודת פרמיה לא מופקעת
  uprValue        Decimal  @db.Decimal(15, 2)

  // DUC — הוצאות רכישה נדחות (IFRS17 PAA)
  dacGross        Decimal  @default(0) @db.Decimal(15, 2) // עמלת סוכן נדחית (נכס)
  deferredRIComm  Decimal  @default(0) @db.Decimal(15, 2) // עמלת ב"מ נדחית (הכנסה נדחית)
  ducNet          Decimal  @default(0) @db.Decimal(15, 2) // DUC נטו = DAC - עמלת ב"מ נדחית

  calculatedAt    DateTime @default(now())

  @@unique([year, period, periodType, branchNumber])
}

// הקצאת הוצאות הנה"כ לענפים — נשמרת בכל חישוב UPR
model AdminExpenseAllocation {
  id                  String   @id @default(cuid())
  year                Int
  month               Int
  branchNumber        Int

  // הקצאה מחושבת
  premiumExpenseShare Float    // חלק מהוצאות הפרמיה (לפי משקל פרמיה שהורווחה)
  claimsExpenseShare  Float    // חלק מהוצאות התביעות (לפי משקל תביעות צפויות)
  totalExpenseShare   Float    // סה"כ הוצאות לענף

  // הכרה בהוצאות — בדומה לפרמיה (IFRS17)
  recognizedExpense   Float    // הוצאה שהוכרה = totalExpenseShare × (1 − uprRatio)
  deferredExpense     Float    // הוצאה נדחית  = totalExpenseShare × uprRatio

  updatedAt           DateTime @updatedAt

  @@unique([year, month, branchNumber])
}

// טבלה חדשה לאחסון פרמטרים של ענפים לשנה מסוימת
model BranchParameters {
  id                   String   @id @default(cuid())
  year                 Int
  branchNumber         Int
  expectedGrossPremium Float // פרמיה צפויה לשנה
  agentCommPct         Float // אחוז עמלת סוכן
  reinsurancePct       Float // אחוז ביטוח משנה
  reinsuranceCommPct   Float // עמלה ממבטח משנה
  expectedLrPct        Float // אחוז Loss Ratio צפוי
  updatedAt            DateTime @updatedAt

  @@unique([year, branchNumber]) // מבטיח שורה אחת לכל ענף בשנה מסוימת
}

// פרמיות אמת חודשיות לפי ענף — כולל תאריכי כיסוי לחישוב UPR/DAC
model PremiumActuals {
  id                 String   @id @default(cuid())
  year               Int
  month              Int
  branchNumber       Int
  startDate          DateTime // תחילת תקופת הביטוח (לחישוב Pro-Rata)
  endDate            DateTime // סוף תקופת הביטוח   (לחישוב Pro-Rata)
  grossPremium       Float    // פרמיה ברוטו
  agentComm          Float    // עמלת סוכן ששולמה
  reinsurancePremium Float    // פרמיה למבטח משנה
  reinsuranceComm    Float    // עמלה שהתקבלה ממבטח משנה
  updatedAt          DateTime @updatedAt

  @@unique([year, month, branchNumber])
}

// תביעות אמת לפי ענף, שנת חיתום ושנת נזק
model ClaimsActuals {
  id               String   @id @default(cuid())
  year             Int      // שנת דיווח (חודש הקליטה)
  month            Int      // חודש דיווח
  branchNumber     Int
  underwritingYear Int      // שנת חיתום (Underwriting Year)
  lossYear         Int      // שנת נזק (Loss Year / Accident Year)
  claimsPaidGross  Float    // תביעות ששולמו ברוטו
  claimsPaidRi     Float    // חלק מבטח משנה בתביעות ששולמו
  updatedAt        DateTime @updatedAt

  @@unique([year, month, branchNumber, underwritingYear, lossYear])
}

// טבלת ענפים — שמות וקיבוצים לצורך דיווח
model Branch {
  branchNumber Int    @id
  branchName   String // שם הענף (למשל: "רכב חובה")
  groupCode    String // קוד קיבוץ (למשל: "CAR")
  groupName    String // שם הקיבוץ (למשל: "ענפי רכב")
  updatedAt    DateTime @updatedAt
}

// הוצאות הנהלה וכלליות חודשיות (לפי IFRS17)
model AdminExpense {
  id             String   @id @default(cuid())
  year           Int
  month          Int
  premiumExpense Float    // הוצאות המיוחסות לפרמיה (יוקצו לפי פרמיה שהורווחה)
  claimsExpense  Float    // הוצאות המיוחסות לתביעות (יוקצו לפי תביעות צפויות)
  description    String?
  updatedAt      DateTime @updatedAt

  @@unique([year, month])
}

// עדכון מודל הערכות אקטואריות (תביעות תלויות/IBNR)
model ActuarialEstimate {
  id                     String   @id @default(cuid())
  year                   Int
  month                  Int
  branchNumber           Int
  underwritingYear       Int      // שנת חיתום (Underwriting Year)
  lossYear               Int      // שנת נזק (Loss Year / Accident Year)
  outstandingClaimsGross Float    // תביעות תלויות ברוטו
  outstandingClaimsRi    Float    // חלק מבטח משנה בתביעות תלויות
  ibnrGross              Float    // IBNR ברוטו
  ibnrRi                 Float    // IBNR חלק מבטח משנה
  actuarialEstimateGross Float    @default(0) // הערכה אקטוארית כוללת ברוטו (תלויות + IBNR + התאמות)
  actuarialEstimateRi    Float    @default(0) // הערכה אקטוארית כוללת חלק ב"מ
  updatedAt              DateTime @updatedAt

  @@unique([year, month, branchNumber, underwritingYear, lossYear])
}
